{
    "name": "appin/appinio-search",
    "description": "WooCommerce integration for AppIn AI Search",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.2",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/woocommerce-stubs": "^10.9"
    },
    "autoload": {
        "psr-4": {
            "AppInIo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppInIo\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:filter": "phpunit --filter",
        "format": "pint",
        "lint": "pint --test",
        "analyse": "phpstan analyse --memory-limit=1G"
    }
}
