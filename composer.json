{
    "name": "appin/appin-search",
    "description": "WooCommerce integration for AppIn AI Search",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "AppIn\\WooCommerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppIn\\WooCommerce\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:filter": "phpunit --filter"
    }
}
