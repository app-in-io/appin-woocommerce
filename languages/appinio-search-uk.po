msgid "Appinio Search"
msgstr "Appinio Search"

msgid "Sync WooCommerce products with Appinio AI Search. Real-time hooks + bulk sync."
msgstr "Синхронізація товарів WooCommerce з Appinio AI Search. Хуки в реальному часі + масова синхронізація."

msgid "Appinio Search requires WooCommerce to be installed and active."
msgstr "Для роботи Appinio Search потрібно встановити та активувати WooCommerce."

msgid "Connection"
msgstr "З'єднання"

msgid "Connect your WooCommerce store to Appinio AI Search."
msgstr "Підключіть свій магазин WooCommerce до Appinio AI Search."

msgid "API Key"
msgstr "API-ключ"

msgid "Auto Sync"
msgstr "Автосинхронізація"

msgid "Search Widget"
msgstr "Віджет пошуку"

msgid "Configure the live search widget that appears on your store."
msgstr "Налаштуйте живий віджет пошуку, що з'являється у вашому магазині."

msgid "Public Key"
msgstr "Публічний ключ"

msgid "Search Input Selector"
msgstr "Селектор поля пошуку"

msgid "Your Appinio API key. Found in the %s under Sites > API Keys."
msgstr "Ваш API-ключ Appinio. Знаходиться в %s у розділі Sites > API Keys."

msgid "Automatically sync products when created, updated, or deleted."
msgstr "Автоматично синхронізувати товари при створенні, оновленні або видаленні."

msgid "Public key for the search widget. Safe to expose in browser. Found in the %s under Sites > API Keys."
msgstr "Публічний ключ для віджета пошуку. Безпечно використовувати у браузері. Знаходиться в %s у розділі Sites > API Keys."

msgid "Custom CSS selector for the search input. Leave empty to use automatic detection."
msgstr "Власний CSS-селектор для поля пошуку. Залиште порожнім для автоматичного визначення."

msgid "Appinio dashboard"
msgstr "панель керування Appinio"

msgid "Getting started"
msgstr "Початок роботи"

msgid "Create a free account at %s."
msgstr "Створіть безкоштовний обліковий запис на %s."

msgid "Copy your API key from the %s under Sites > API Keys."
msgstr "Скопіюйте свій API-ключ із %s у розділі Sites > API Keys."

msgid "Paste it below, save, then run Sync All Products."
msgstr "Вставте його нижче, збережіть і запустіть «Синхронізувати всі товари»."

msgid "Create a free Appinio account"
msgstr "Створити безкоштовний обліковий запис Appinio"

msgid "Sync Status"
msgstr "Стан синхронізації"

msgid "Published products"
msgstr "Опубліковані товари"

msgid "Synced"
msgstr "Синхронізовано"

msgid "Last sync"
msgstr "Остання синхронізація"

msgid "Sync in progress..."
msgstr "Синхронізація триває…"

msgid "Sync All Products"
msgstr "Синхронізувати всі товари"

msgid "This will remove all products from Appinio index. Continue?"
msgstr "Це видалить усі товари з індексу Appinio. Продовжити?"

msgid "Delete All from Index"
msgstr "Видалити все з індексу"

msgid "Unauthorized."
msgstr "Немає доступу."

